{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"username": "testuser_yg", "display_name": "Тест Юзер", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"username": "testuser_yg", "password": "password123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"username": "testuser_yg", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Register duplicate username",
      "method": "POST",
      "path": "/?action=register",
      "body": {"username": "testuser_yg", "display_name": "Дубль", "password": "pass123456"},
      "expectedStatus": 409,
      "bodyMatcher": "partial"
    }
  ]
}